---
const wa = "https://wa.me/971523620668";
---
<section id="contact" class="section relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none"
       style="background: radial-gradient(60% 60% at 50% 100%, rgba(255,59,67,0.16), transparent 70%);"></div>

  <div class="container-x relative">
    <div class="rounded-[2rem] border border-[var(--color-line)] bg-[var(--color-ink-2)] p-8 md:p-14 text-center ring-glow" data-reveal>
      <p class="eyebrow justify-center" style="display:inline-flex;">Get StormView</p>
      <h2 class="mt-5 text-[clamp(2.2rem,5.5vw,4rem)] font-bold leading-[1.02]">
        Secure your space today.
      </h2>
      <p class="mt-5 text-[var(--color-mist)] text-lg max-w-xl mx-auto">
        Distributor pricing, project quotes and bulk supply across the UAE, Saudi Arabia and the GCC.
        Message us — we usually reply within the hour.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href={wa} target="_blank" rel="noopener" class="btn-primary" data-magnetic>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 004.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0012.04 2zm5.8 14.16c-.25.7-1.44 1.33-1.99 1.41-.51.08-1.15.11-1.86-.12-.43-.14-.98-.32-1.69-.62-2.97-1.28-4.91-4.27-5.06-4.47-.15-.2-1.21-1.61-1.21-3.07s.77-2.18 1.04-2.48c.27-.3.59-.37.79-.37.2 0 .4 0 .57.01.18.01.43-.07.67.51.25.6.84 2.06.91 2.21.07.15.12.32.02.52-.1.2-.15.32-.3.5-.15.18-.31.39-.45.53-.15.15-.3.31-.13.6.17.3.77 1.27 1.65 2.06 1.14 1.01 2.1 1.33 2.4 1.48.3.15.47.12.65-.07.18-.2.74-.86.94-1.16.2-.3.4-.25.67-.15.27.1 1.72.81 2.02.96.3.15.5.22.57.35.07.12.07.72-.18 1.42z"/></svg>
          Chat on WhatsApp
        </a>
        <a href="mailto:info@stormview.online" class="btn-ghost" data-magnetic>info@stormview.online</a>
      </div>

      <div class="mt-12 pt-8 border-t border-[var(--color-line)] grid sm:grid-cols-3 gap-6 text-sm">
        <div>
          <div class="text-[var(--color-mist)] text-xs uppercase tracking-wider">Phone</div>
          <a href="tel:+971523620668" class="mt-1 block font-medium hover:text-[var(--color-crimson-bright)] transition-colors">+971 52 362 0668</a>
        </div>
        <div>
          <div class="text-[var(--color-mist)] text-xs uppercase tracking-wider">Email</div>
          <a href="mailto:info@stormview.online" class="mt-1 block font-medium hover:text-[var(--color-crimson-bright)] transition-colors">info@stormview.online</a>
        </div>
        <div>
          <div class="text-[var(--color-mist)] text-xs uppercase tracking-wider">Based in</div>
          <div class="mt-1 font-medium">Dubai, UAE</div>
        </div>
      </div>
    </div>
  </div>
</section>

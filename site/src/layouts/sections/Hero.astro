---
const wa = "https://wa.me/971523620668";

// pool of feeds the 4 monitors rotate through (like switching CCTV channels)
const pool = [
  { name: "SV-4GS2L", img: "/images/battery.jpeg" },
  { name: "SV-4GS2L V2", img: "/images/v2-main.jpg" },
  { name: "4G LTE Solar 8MP", img: "/images/8mp-main.jpg" },
  { name: "Indoor Monitor", img: "/images/indoor-monitor.jpg" },
  { name: "Screen Baby Monitor", img: "/images/screen-monitor.jpg" },
  { name: "V2 · Night", img: "/images/v2-night.jpg" },
  { name: "Dual-Lens", img: "/images/dual-lens.jpeg" },
  { name: "Pan & Tilt", img: "/images/pan-tilt.jpeg" },
];
// the 4 monitors (fixed CAM ids) start on the first four feeds
const panels = [0, 1, 2, 3].map((i) => ({ cam: `CAM 0${i + 1}`, ...pool[i] }));
---
<section id="hero" class="relative min-h-[100svh] flex items-center overflow-hidden">
  <!-- ambient backdrop -->
  <div class="absolute inset-0 bg-grid"></div>
  <div class="absolute inset-0 pointer-events-none"
       style="background: radial-gradient(60% 50% at 70% 40%, rgba(255,59,67,0.12), transparent 70%);"></div>
  <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[120vw] h-[60vh] pointer-events-none"
       style="background: radial-gradient(ellipse at center, rgba(176,37,42,0.16), transparent 65%);"></div>
  <!-- sweeping searchlight (security motif) -->
  <div class="searchlight" aria-hidden="true"></div>
  <div class="searchlight-source" aria-hidden="true"></div>

  <div class="container-x relative z-10 grid lg:grid-cols-2 gap-10 items-center pt-28 pb-16">
    <!-- copy -->
    <div>
      <p class="eyebrow" data-reveal>Solar · 4G LTE · AI Detection</p>
      <h1 class="mt-6 text-[clamp(2.6rem,7vw,5.2rem)] leading-[0.98] font-bold" data-reveal data-reveal-delay="0.05">
        The camera that<br />
        <span class="text-glow text-[var(--color-crimson-bright)]">never sleeps.</span>
      </h1>
      <p class="mt-6 max-w-md text-[var(--color-mist)] text-lg leading-relaxed" data-reveal data-reveal-delay="0.12">
        StormView solar-powered security cameras keep watch around the clock — dual-lens vision with no blind spots,
        full-color night monitoring and instant mobile alerts. No wiring. No monthly limits.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3" data-reveal data-reveal-delay="0.18">
        <a href="#features" class="btn-primary" data-magnetic>
          Explore the SV-4GS2L
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href={wa} target="_blank" rel="noopener" class="btn-ghost" data-magnetic>Talk to sales</a>
      </div>

      <!-- mini stats -->
      <div class="mt-12 flex gap-8" data-reveal data-reveal-delay="0.24">
        <div>
          <div class="font-display text-2xl font-semibold"><span data-count="10800" data-suffix="">0</span></div>
          <div class="text-xs text-[var(--color-mist)] tracking-wide mt-1">mAh solar battery</div>
        </div>
        <div class="w-px bg-[var(--color-line)]"></div>
        <div>
          <div class="font-display text-2xl font-semibold"><span data-count="360" data-suffix="°">0</span></div>
          <div class="text-xs text-[var(--color-mist)] tracking-wide mt-1">pan coverage</div>
        </div>
        <div class="w-px bg-[var(--color-line)]"></div>
        <div>
          <div class="font-display text-2xl font-semibold">IP66</div>
          <div class="text-xs text-[var(--color-mist)] tracking-wide mt-1">weatherproof</div>
        </div>
      </div>
    </div>

    <!-- live surveillance wall -->
    <div class="relative mx-auto w-full max-w-md lg:max-w-none" data-reveal data-reveal-delay="0.1">
      <div class="absolute inset-0 -m-10 rounded-full blur-3xl pointer-events-none"
           style="background: radial-gradient(circle, rgba(255,59,67,0.18), transparent 60%);"></div>
      <div class="relative rounded-3xl overflow-hidden ring-glow bg-[#08090b]" data-wall data-pool={JSON.stringify(pool)}>
        <!-- monitor header bar -->
        <div class="flex items-center justify-between px-4 pt-3.5 pb-2.5 border-b border-white/5">
          <div class="flex items-center gap-2 font-display text-[0.62rem] tracking-[0.18em] text-[var(--color-steel-light)]">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-crimson-bright)] animate-pulse"></span>
            STORMVIEW · LIVE MONITOR
          </div>
          <div class="flex items-center gap-3 text-[0.6rem] tracking-wider text-[var(--color-mist)] font-display">
            <span data-clock>00:00:00</span>
            <span class="hidden sm:inline">CH 01–04</span>
          </div>
        </div>
        <!-- 2x2 camera feeds -->
        <div class="grid grid-cols-2 gap-1.5 p-1.5">
          {panels.map((f, i) => (
            <div class="feed relative aspect-square overflow-hidden rounded-md bg-black" data-cur={i}>
              <img src={f.img} alt={f.name} class="feed-img absolute inset-0 w-full h-full object-cover" style={`animation-delay:-${i * 3.5}s`} />
              <div class="absolute inset-0 feed-grade pointer-events-none"></div>
              <div class="absolute inset-0 scanlines pointer-events-none"></div>
              <div class="feed-sweep pointer-events-none"></div>
              <div class="absolute inset-0 feed-vignette pointer-events-none"></div>
              <div class="absolute inset-0 feed-glitch pointer-events-none"></div>
              <!-- HUD top -->
              <div class="absolute top-1.5 left-2 right-2 flex items-center justify-between text-[0.5rem] font-display tracking-wider text-white/85">
                <span>{f.cam}</span>
                <span class="rec flex items-center gap-1"><span class="w-1 h-1 rounded-full bg-red-500"></span>REC</span>
              </div>
              <!-- HUD bottom -->
              <div class="absolute bottom-1.5 left-2 right-2 flex items-center justify-between text-[0.5rem] font-display tracking-wide text-white/80">
                <span class="truncate max-w-[62%]" data-feed-name>{f.name}</span>
                <span data-clock-cell>00:00:00</span>
              </div>
            </div>
          ))}
        </div>
      </div>
      <!-- status chip -->
      <div class="absolute -left-4 bottom-8 bg-[var(--color-ink-3)]/95 backdrop-blur border border-[var(--color-line)] rounded-2xl px-4 py-2.5 shadow-2xl">
        <div class="flex items-center gap-2 text-[0.82rem] font-medium">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span> 4 cameras · live
        </div>
      </div>
    </div>
  </div>

  <!-- scroll cue -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[var(--color-mist)]">
    <span class="text-[0.65rem] tracking-[0.3em] uppercase">Scroll</span>
    <span class="w-px h-10 bg-gradient-to-b from-[var(--color-crimson)] to-transparent"></span>
  </div>
</section>

<style>
  /* Ken Burns drift — transform only (compositor-friendly, no jank) */
  .feed-img { animation: kenburns 17s ease-in-out infinite alternate; will-change: transform; }
  @keyframes kenburns {
    0%   { transform: scale(1.06) translate(1.5%, 1%); }
    100% { transform: scale(1.15) translate(-2%, -1.5%); }
  }
  .feed:nth-child(2) .feed-img { animation-duration: 20s; }
  .feed:nth-child(3) .feed-img { animation-duration: 23s; }
  .feed:nth-child(4) .feed-img { animation-duration: 18.5s; }

  /* CCTV color grade — static cool tint, no blend/filter on animated layers */
  .feed-grade { background: linear-gradient(180deg, rgba(30,60,90,0.16), rgba(0,0,0,0.06) 60%, rgba(0,0,0,0.18)); }
  .scanlines {
    background: repeating-linear-gradient(to bottom, rgba(0,0,0,0) 0, rgba(0,0,0,0) 2px, rgba(0,0,0,0.16) 3px);
    opacity: 0.5;
  }
  .feed-vignette { box-shadow: inset 0 0 26px rgba(0,0,0,0.6); }

  /* scan sweep — thin bright bar translating down */
  .feed-sweep {
    position: absolute; left: 0; right: 0; top: 0; height: 42%;
    background: linear-gradient(to bottom, transparent, rgba(150,210,255,0.07), transparent);
    animation: feedsweep 6s linear infinite; will-change: transform;
  }
  .feed:nth-child(2) .feed-sweep { animation-duration: 7.6s; }
  .feed:nth-child(3) .feed-sweep { animation-duration: 5.4s; }
  .feed:nth-child(4) .feed-sweep { animation-duration: 8.2s; }
  @keyframes feedsweep { 0% { transform: translateY(-110%); } 100% { transform: translateY(260%); } }

  .rec { color: #ff6b6b; animation: recblink 1.6s steps(1, end) infinite; }
  @keyframes recblink { 0%, 55% { opacity: 1; } 56%, 100% { opacity: 0.3; } }

  /* channel switch — dim the feed + glitch flash while the source swaps */
  .feed-img { transition: opacity 0.18s ease; }
  .feed.switching .feed-img { opacity: 0.18; }
  .feed-glitch { opacity: 0; }
  .feed.switching .feed-glitch { animation: chglitch 0.46s steps(2, end); }
  @keyframes chglitch {
    0%   { opacity: 0; }
    12%  { opacity: 0.65; background: rgba(170,205,255,0.5); transform: translateX(-2.5%); }
    28%  { opacity: 0.15; transform: translateX(3%); }
    46%  { opacity: 0.7; background: rgba(255,255,255,0.32); transform: translateX(0); }
    70%  { opacity: 0.1; }
    100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .feed-img, .feed-sweep, .rec { animation: none; }
    .feed-img { transform: scale(1.06); }
  }
</style>

---
const wa = "https://wa.me/971523620668";

const models = [
  {
    name: "SV-4GS2L",
    badge: "Flagship",
    tagline: "Dual-lens 4MP · solar 4G workhorse",
    img: "/images/battery.jpeg",
    featured: true,
    highlight: "10,800",
    highlightUnit: "mAh",
    highlightLabel: "Biggest battery",
    available: true,
  },
  {
    name: "SV-4GS2L V2",
    badge: "Dual-Screen 2K",
    tagline: "Dual-lens, dual-screen with AI human detection",
    img: "/images/v2-main.jpg",
    highlight: "2K",
    highlightUnit: "",
    highlightLabel: "Dual-screen view",
    available: true,
  },
  {
    name: "4G LTE Solar 8MP",
    badge: "8MP",
    tagline: "Highest resolution · full-color night",
    img: "/images/8mp-main.jpg",
    tileLight: true,
    highlight: "8MP",
    highlightUnit: "",
    highlightLabel: "Sharpest sensor",
    available: true,
  },
];

// rows: [label, SV-4GS2L, V2, 8MP]
const specs = [
  ["Resolution", "4MP dual-lens", "2K dual-screen", "8MP"],
  ["Battery", "10,800 mAh", "6,000 mAh", "~10,400 mAh"],
  ["Solar panel", "7.5W", "7.5W", "Yes"],
  ["Connectivity", "4G LTE + SIM", "4G LTE + SIM", "4G LTE + SIM"],
  ["Night vision", "Full-color + IR", "Full-color + IR", "Full-color"],
  ["Pan / Tilt", "360° / 90°", "355° / 90°", "360° / 90°"],
  ["AI detection", "PIR + humanoid", "PIR + AI human · 10m", "Motion detection"],
  ["Audio", "Two-way", "Two-way full-duplex", "Two-way"],
  ["Storage", "microSD + cloud", "microSD 32–256GB + cloud", "microSD + cloud"],
  ["Weatherproof", "IP66", "IP66 · −30~60°C", "IP66"],
];
---
<section id="range" class="section">
  <div class="container-x">
    <div class="max-w-2xl">
      <p class="eyebrow" data-reveal>The Range</p>
      <h2 class="mt-5 text-[clamp(2rem,5vw,3.4rem)] font-bold leading-[1.05]" data-reveal data-reveal-delay="0.05">
        Pick the StormView<br />that fits your site.
      </h2>
      <p class="mt-5 text-[var(--color-mist)] text-lg" data-reveal data-reveal-delay="0.1">
        Three solar 4G models, one app. From the big-battery flagship to the dual-screen 2K and the
        8MP detail king — compare them side by side.
      </p>
    </div>

    <!-- model cards -->
    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5" data-reveal-group>
      {models.map((m) => (
        <article class={`group relative rounded-2xl overflow-hidden border bg-[var(--color-ink-3)] flex flex-col ${m.featured ? "border-[var(--color-crimson)]/50 ring-1 ring-[var(--color-crimson)]/30" : "border-[var(--color-line)]"}`}
                 data-reveal-item style="opacity:0; transform:translateY(28px);">
          <div class={`relative aspect-square overflow-hidden ${m.tileLight ? "bg-gradient-to-b from-white to-[#e6eaee]" : "bg-gradient-to-b from-[var(--color-ink-2)] to-[var(--color-ink)]"}`}>
            {m.img ? (
              <img src={m.img} alt={m.name} class="w-full h-full object-contain p-3 transition-transform duration-700 group-hover:scale-105" />
            ) : (
              <div class="w-full h-full flex flex-col items-center justify-center gap-3 text-[var(--color-mist)]">
                <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="6" width="18" height="13" rx="2"/><circle cx="12" cy="12.5" r="3.2"/><path d="M8 6l1.5-2h5L16 6"/></svg>
                <span class="text-xs tracking-wide">Photos coming soon</span>
              </div>
            )}
            <span class={`absolute top-3 left-3 text-[0.65rem] font-semibold tracking-wide px-2.5 py-1 rounded-full ${m.featured ? "bg-[var(--color-crimson)] text-white" : "bg-[var(--color-ink)]/70 border border-[var(--color-line)] text-[var(--color-steel-light)]"}`}>{m.badge}</span>
            {!m.available && <span class="absolute top-3 right-3 text-[0.6rem] font-semibold tracking-wide px-2 py-1 rounded-full bg-[var(--color-ink)]/80 border border-[var(--color-line)] text-[var(--color-mist)]">SOON</span>}
          </div>

          <div class="p-5 flex flex-col flex-1">
            <h3 class="font-display text-lg font-semibold">{m.name}</h3>
            <p class="mt-1 text-sm text-[var(--color-mist)] leading-relaxed">{m.tagline}</p>
            <div class="mt-4 pt-4 border-t border-[var(--color-line)] flex items-end justify-between">
              <div>
                <div class="font-display text-2xl font-bold leading-none">
                  {m.highlight}<span class="text-base text-[var(--color-steel)]">{m.highlightUnit}</span>
                </div>
                <div class="text-[0.7rem] text-[var(--color-mist)] mt-1 uppercase tracking-wider">{m.highlightLabel}</div>
              </div>
              <a href={wa} target="_blank" rel="noopener" aria-label={`Ask about ${m.name}`}
                 class="grid place-items-center w-10 h-10 rounded-full border border-[var(--color-line)] text-[var(--color-fog)] group-hover:border-[var(--color-crimson)] group-hover:bg-[var(--color-crimson)] transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- comparison table -->
    <div class="mt-14" data-reveal>
      <h3 class="font-display text-xl font-semibold mb-5">Full comparison</h3>
      <div class="overflow-x-auto rounded-2xl border border-[var(--color-line)]">
        <table class="w-full min-w-[680px] text-sm border-collapse">
          <thead>
            <tr class="bg-[var(--color-ink-3)]">
              <th class="text-left font-medium text-[var(--color-mist)] px-5 py-4 w-[24%]">Spec</th>
              {models.map((m) => (
                <th class={`text-left px-5 py-4 font-display font-semibold ${m.featured ? "text-[var(--color-crimson-bright)]" : "text-[var(--color-fog)]"}`}>
                  {m.name}{m.featured && <span class="ml-1.5 text-[0.6rem] align-middle bg-[var(--color-crimson)] text-white px-1.5 py-0.5 rounded-full">★</span>}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {specs.map(([label, ...vals], i) => (
              <tr class={i % 2 ? "bg-[var(--color-ink-2)]" : "bg-[var(--color-ink)]"}>
                <td class="px-5 py-3.5 text-[var(--color-mist)] border-t border-[var(--color-line)]">{label}</td>
                {vals.map((v, ci) => (
                  <td class={`px-5 py-3.5 border-t border-[var(--color-line)] ${models[ci].featured ? "text-[var(--color-fog)] font-medium" : "text-[var(--color-steel-light)]"}`}>{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-[var(--color-mist)]">Specs per StormView product sheets. Final figures may vary by batch — confirm on quote.</p>
    </div>
  </div>
</section>
